{
  "name": "virtual-cosmos",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:shared": "npm run build -w @virtual-cosmos/shared",
    "postinstall": "npm run build -w @virtual-cosmos/shared",
    "dev:web": "npm run dev -w web",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w @virtual-cosmos/shared && npm run build -w web && npm run build -w server"
  },
  "engines": {
    "node": ">=18"
  }
}
