# Copy this file to the REPOSITORY ROOT as `.env` (not only inside apps/web).
# Both the server and Vite load env from there.

# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Optional: only if you run MongoDB locally. If unset, the app still works (in-memory only).
# MONGODB_URI=mongodb://127.0.0.1:27017/virtual-cosmos

# Web — must match where Socket.IO listens (same as PORT above unless you proxy).
VITE_SOCKET_URL=http://localhost:3001
